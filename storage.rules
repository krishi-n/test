rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /bundles/{bundleId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null 
        && (resource.metadata.authorId == request.auth.uid 
            || firestore.get(/databases/$(database)/documents/bundles/$(bundleId)).data.authorId == request.auth.uid);
    }
  }
}
